server {
    listen 80;
    server_name inova.codermaster.com.br;
    root /www/wwwroot/inova.codermaster.com.br/public;
    index index.php;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass unix:/tmp/php-cgi-83.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;

        # Variáveis de ambiente para o app
        fastcgi_param DB_HOST localhost;
        fastcgi_param DB_NAME inova;
        fastcgi_param DB_USER inova;
        fastcgi_param DB_PASS XDxbLEmy7HyRnmkL;
        fastcgi_param APP_URL https://inova.codermaster.com.br;
    }

    location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # Bloquear acesso a arquivos sensíveis
    location ~ /\.(env|git|htaccess) {
        deny all;
    }
}
